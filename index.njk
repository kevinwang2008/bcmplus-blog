---
layout: base.njk
pagination:
  data: collections.posts
  size: 30
  alias: pagePosts
---

<h2 style="margin-bottom:30px;">全部文章</h2>

{% if pagination.pageLinks.length > 1 %}
<div style="margin-bottom:20px;font-size:14px;color:#888;">
  第 {{ pagination.pageNumber + 1 }} / {{ pagination.pages.length }} 页
</div>
{% endif %}

{% for post in pagePosts %}
<div style="margin-bottom:18px;padding-bottom:18px;border-bottom:1px solid #f0f0f0;">
  <a href="/{{ post.page.fileSlug }}/" style="font-size:16px;color:#333;text-decoration:none;display:block;">
    <strong>{{ post.data.title }}</strong>
  </a>
  <div style="font-size:13px;color:#999;margin-top:4px;">
    {{ post.data.date | default('') | slice(0, 10) }}
  </div>
</div>
{% endfor %}

{% if pagination.pageLinks.length > 1 %}
<div style="margin-top:30px;text-align:center;">
  {% if pagination.href.previous %}
    <a href="{{ pagination.href.previous }}" style="margin-right:15px;color:#a4c639;">← 上一页</a>
  {% endif %}
  {% if pagination.href.next %}
    <a href="{{ pagination.href.next }}" style="color:#a4c639;">下一页 →</a>
  {% endif %}
</div>
{% endif %}
